@startuml
left to right direction
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam shadowing false

actor Guest as "Гость"

rectangle "Информационный портал" as System {
  usecase "UC4\nПросмотр гороскопов" as UC4
  usecase "Выбрать знак\nзодиака" as UC4A
  usecase "Показать прогноз\nна период" as UC4B
  usecase "Просмотреть прогноз\nпо категориям" as UC4C
}

Guest --> UC4
UC4 .> UC4A : <<include>>
UC4 .> UC4B : <<include>>
UC4 .> UC4C : <<include>>
@enduml
